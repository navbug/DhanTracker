# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dhan_tracker"

# NextAuth
AUTH_SECRET="your-secret-here-run-npx-auth-secret"
NEXTAUTH_URL="https://stellular-bubblegum-529a2f.netlify.app"

# Google OAuth (optional)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# AWS S3 (for trade screenshots)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET_NAME="dhan-tracker-screenshots"

# Email — Resend (for password reset emails)
# Get your API key at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be a verified sender domain in your Resend account
EMAIL_FROM="DhanTracker <noreply@yourdomain.com>"
# Email address where contact form submissions are delivered
CONTACT_OWNER_EMAIL="you@yourdomain.com"
