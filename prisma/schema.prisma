// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH MODELS (NextAuth v5) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?   // null for OAuth users
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  watchlists  Watchlist[]
  trades      Trade[]
  research    Research[]
  stockNotes  StockNote[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── PASSWORD RESET ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

// ─── WATCHLIST MODELS ────────────────────────────────────────────────────────

// NOTE: Pre-defined watchlists (Nifty50, Nifty100, Midcap150, Smallcap250)
// are stored as static JSON files in /src/data/indices/ — NOT in the DB.
// Only custom user-created watchlists are stored here.

model Watchlist {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stocks WatchlistStock[]

  @@unique([userId, name]) // User can't have two watchlists with same name
  @@map("watchlists")
}

model WatchlistStock {
  id          String   @id @default(cuid())
  symbol      String   // NSE symbol e.g. "RELIANCE", "INFY"
  watchlistId String
  position    Int      @default(0) // For drag-and-drop ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol]) // No duplicate stocks in a watchlist
  @@index([watchlistId])
  @@map("watchlist_stocks")
}

// ─── STOCK NOTE MODEL ────────────────────────────────────────────────────────
// One note per stock per user — shared across ALL custom watchlists.

model StockNote {
  id        String   @id @default(cuid())
  userId    String
  symbol    String   // NSE symbol (uppercase)
  note      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
  @@map("stock_notes")
}

// ─── TRADE LEDGER MODELS ─────────────────────────────────────────────────────

enum TradeSetup {
  QUICK_TRADE // Quick trades - intraday
  HIT         // Half In Trade
  DIT         // Daily In Trade  
  WIT         // Weekly In Trade
  MIT         // Monthly In Trade
  QIT         // Quarterly In Trade
  HYIT        // Half Yearly In Trade
  YIT         // Yearly In Trade
}

enum TradePriority {
  MUST_TRADE
  HIGH
  MEDIUM
  LOW
}

enum TradeOutcome {
  OPEN
  TARGET_HIT
  SL_HIT
  PARTIAL_PROFIT
  BREAKEVEN
  MANUAL_EXIT
}

model Trade {
  id         String        @id @default(cuid())
  userId     String
  date       DateTime
  stock      String        // NSE symbol
  tradeSetup TradeSetup
  priority   TradePriority
  entry      Float
  sl         Float         // Stop Loss
  target     Float
  qty        Int
  outcome    TradeOutcome  @default(OPEN)
  timeTaken  String?       // e.g. "2 days", "3 hours"
  remark     String?       @db.Text
  screenshots String[]     @default([]) // S3 URLs
  pnl        Float?        // Calculated: (exit - entry) * qty (negative for loss)
  exitPrice  Float?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, outcome])
  @@index([userId, tradeSetup])
  @@map("trades")
}

// ─── RESEARCH MODELS ─────────────────────────────────────────────────────────

enum ResearchCategory {
  MARKET
  SECTOR
  STOCK
  PERSONAL
}

model Research {
  id          String           @id @default(cuid())
  userId      String
  title       String
  category    ResearchCategory
  description String?          @db.Text
  canvas      Json?            // tldraw JSON snapshot
  thumbnail   String?          // S3 URL of canvas thumbnail
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@map("research")
}
